# =============================================
# DROPLUCK — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez vos clés
# =============================================

# SUPABASE (récupérer sur https://supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJVOTRE_CLE_ANON...
SUPABASE_SERVICE_ROLE_KEY=eyJVOTRE_SERVICE_ROLE_KEY...

# PAIEMENTS
# Wave: lien direct (déjà configuré dans le code)
NEXT_PUBLIC_WAVE_PAYMENT_URL=https://pay.wave.com/m/M_ci_qj5yNpWbOfPI/c/ci/?amount=11

# Orange Money: numéro de réception
NEXT_PUBLIC_OM_NUMBER=+225 07 14 39 45 27

# ADMIN (email de l'administrateur du site)
NEXT_PUBLIC_ADMIN_EMAIL=votre@email.com

# PRIX PAR TIRAGE (en FCFA)
NEXT_PUBLIC_PRIX_TIRAGE=11
NEXT_PUBLIC_TIRAGES_GRATUITS=2
